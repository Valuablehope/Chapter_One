{
  "name": "chapter-one-electron",
  "version": "4.0.8",
  "description": "Electron main process for Chapter One POS",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "postinstall": "electron-rebuild -f -w serialport"
  },
  "dependencies": {
    "electron": "^39.2.7",
    "electron-log": "^5.4.3",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
