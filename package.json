{
  "name": "chapter-one-pos",
  "version": "4.0.0",
  "description": "Chapter One POS Desktop Application",
  "main": "electron/dist/main.js",
  "author": "Chapter One",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others -n \"backend,frontend,electron\" -c \"blue,green,yellow\" \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:electron": "cross-env ELECTRON_IS_DEV=true wait-on http://127.0.0.1:5173 http://127.0.0.1:3001 && cd electron && cross-env ELECTRON_IS_DEV=true npm run dev",
    "clean": "node scripts/clean-build.js && npm run clean:dist",
    "clean:frontend": "node scripts/clean-build.js",
    "clean:backend": "node scripts/clean-build.js",
    "clean:electron": "node scripts/clean-build.js",
    "clean:dist": "node scripts/clean-dist.js",
    "build": "npm run clean && npm run build:frontend && npm run build:backend && npm run build:electron",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:electron": "cd electron && npm run build",
    "build:win": "npm install && npm run build && npm run install:backend:prod && npm run prune:backend && npx electron-builder --win --publish never",
    "release:win": "npm install && npm run build && npm run install:backend:prod && npm run prune:backend && npx electron-builder --win --publish always",
    "dist": "npm run build:win",
    "install:backend:prod": "cd backend && npm install --omit=dev --no-workspaces",
    "prune:backend": "cd backend && npm prune --production --no-workspaces",
    "start": "cross-env NODE_ENV=production electron .",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install && cd ../electron && npm install",
    "create-user": "cd backend && npm run create-user",
    "create-license": "cd backend && npm run create-license"
  },
  "devDependencies": {
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron-builder": "^26.8.1",
    "rimraf": "^6.1.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.chapterone.pos",
    "productName": "Chapter One POS",
    "directories": {
      "output": "dist-installer",
      "buildResources": "build"
    },
    "asar": true,
    "files": [
      "electron/dist/**/*",
      "frontend/dist/**/*",
      "!**/.env",
      "!**/.env.local",
      "!**/.env.*.local",
      "!backend/**/*",
      "!frontend/src/**/*",
      "!electron/src/**/*",
      "!**/tsconfig.json",
      "!**/*.ts",
      "!**/*.tsx"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "env.example",
        "to": ".env.example"
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!src/**",
          "!test/**",
          "!tsconfig.json",
          "!**/*.map",
          "!**/*.ts",
          "!backend/**",
          "!frontend/**",
          "!node_modules/**"
        ]
      },
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*",
          "!backend/**",
          "!frontend/**"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "frontend/public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "frontend/public/icon.ico",
      "uninstallerIcon": "frontend/public/icon.ico",
      "installerHeaderIcon": "frontend/public/icon.ico",
      "artifactName": "${productName} Setup ${version}.${ext}",
      "shortcutName": "${productName}"
    },
    "publish": {
      "provider": "github",
      "owner": "Valuablehope",
      "repo": "Chapter_One"
    },
    "compression": "maximum",
    "removePackageScripts": true
  },
  "workspaces": [
    "frontend",
    "backend",
    "electron"
  ],
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.1.7",
    "pg": "^8.11.3",
    "winston": "^3.11.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "semver": "^7.5.4"
  }
}