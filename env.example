# Database Configuration
# Option 1: Use connection string (recommended)
DATABASE_URL=postgres://postgres:your_password@localhost:5432/Chapter_One

# Option 2: Use individual variables (if not using DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=Chapter_One
DB_USER=postgres
DB_PASSWORD=your_password_here

# Database Pool Configuration
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Server Configuration
PORT=3001
API_PORT=3001
NODE_ENV=development

# Security
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRY=24h
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# License Encryption Key (32 bytes for AES-256)
# IMPORTANT: Change this to a secure random string in production!
# Generate a secure key: openssl rand -base64 32
LICENSE_ENCRYPTION_KEY=ChapterOneLicenseKey2024!SecureEncryptionKey12345678

# Rate Limiting
# Maximum number of login attempts per 15-minute window
AUTH_RATE_LIMIT_MAX=5
# Maximum number of API requests per 15-minute window
API_RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Electron Configuration
ELECTRON_IS_DEV=true

# Application
APP_NAME=Chapter One POS
APP_VERSION=4.0.0

